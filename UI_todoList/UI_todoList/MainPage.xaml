<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="UI_TodoList.MainPage"
    BackgroundColor="white"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryPurple">#b95d24</Color>
            <Color x:Key="LightPurple">#ce8c5f</Color>
            <Color x:Key="InputBorder">Transparent</Color>
            <Color x:Key="PlaceholderColor">#AAAAAA</Color>
            <Color x:Key="TextColor">#333333</Color>

            <Style x:Key="InputEntryStyle" TargetType="Entry">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="TextColor" Value="{StaticResource TextColor}"/>
                <Setter Property="PlaceholderColor" Value="{StaticResource PlaceholderColor}"/>
                <Setter Property="BackgroundColor" Value="Transparent"/>
                <Setter Property="HeightRequest" Value="48"/>
                <Setter Property="Margin" Value="12,0"/>
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryPurple}"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="HeightRequest" Value="52"/>
                <Setter Property="BorderWidth" Value="0"/>
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource LightPurple}"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="HeightRequest" Value="52"/>
                <Setter Property="BorderWidth" Value="0"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout
            Spacing="0"
            Padding="30,60,30,40"
            VerticalOptions="FillAndExpand">

            
            <Border
                HeightRequest="160"
                WidthRequest="160"
                StrokeThickness="0"
                BackgroundColor="#F0F0F0"
                HorizontalOptions="Center"
                Margin="0,0,0,48">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Image
                    Source="todolistlogo.png"
                    Aspect="AspectFit"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"/>
            </Border>

            <Border
                Stroke="{StaticResource InputBorder}"
                StrokeThickness="1"
                BackgroundColor="Transparent"
                HeightRequest="52"
                >
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Entry
                    x:Name="EmailEntry"
                    Style="{StaticResource InputEntryStyle}"
                    Placeholder="Email address"
                    Keyboard="Email"
                    ReturnType="Next"/>
            </Border>

            <Border
                Stroke="{StaticResource InputBorder}"
                StrokeThickness="1"
                BackgroundColor="Transparent"
                HeightRequest="52"
                Margin="0,0,0,24">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Entry
                    x:Name="PasswordEntry"
                    Style="{StaticResource InputEntryStyle}"
                    Placeholder="Password"
                    IsPassword="True"
                    ReturnType="Done"/>
            </Border>

            <Button
                Text="Sign in"
                Style="{StaticResource PrimaryButtonStyle}"
                Clicked="OnSignInClicked"
                Margin="0,0,0,12"/>

            <Button
                Text="Sign up"
                Style="{StaticResource SecondaryButtonStyle}"
                Clicked="OnSignUpClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>